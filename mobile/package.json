    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@callstack/eslint-config": "^15.0.0",
    "@eslint/js": "^9.39.4",
    "@types/react": "~19.1.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
